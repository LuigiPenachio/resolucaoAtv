from stack import Stack

def is_balanced(expression):
    """
    Verifica se a expressão possui parênteses balanceados.
    Usa a pilha implementada em stack.py.
    """
    pilha = Stack()

    pares = {')': '(', ']': '[', '}': '{'}
    aberturas = set('([{')
    
    for char in expression:
        if char in aberturas:
            pilha.push(char)
        elif char in pares:
            if pilha.is_empty() or pilha.pop() != pares[char]:
                return False
    
    return pilha.is_empty()



print(is_balanced("[{}(2+2)]{}")) 
print(is_balanced("[{}(2+2))]{}")) 
print(is_balanced("[{}])")) 

print(" ")
print(is_balanced(""))                         
print(is_balanced("()"))                      
print(is_balanced("({[]})"))                   
print(is_balanced("{[()()]()}"))               
print(is_balanced("if (a[0] > b) { return c; }")) 

print(" ")
print(is_balanced("("))                       
print(is_balanced("]"))                       
print(is_balanced("({[)]}"))                 
print(is_balanced("{[(()]}"))                  
print(is_balanced("((()))]"))



