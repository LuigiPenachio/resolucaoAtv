from stack import Stack

if __name__ == "__main__":
    main_stack = Stack()
    min_stack = Stack()

    def push_aux(data):
         main_stack.push(data)

    if min_stack.is_empty() or data <= min_stack.peek():
            min_stack.push(data)

    def pop_aux():
      data = main_stack.pop()
        
    if data == min_stack.peek():
            min_stack.pop()
    return data

    def get_min():
      
     return min_stack.peek()

    
    print("\nEmpilhando: 5, 3, 7, 2, 8")
